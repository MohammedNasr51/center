{
  "info": {
    "name": "Vision Center Backend API",
    "description": "Test collection for the Deno-deployable backend that stores center management data in MongoDB.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().ok).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Full App State",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/state?centerId={{centerId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "state"
          ],
          "query": [
            {
              "key": "centerId",
              "value": "{{centerId}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('state endpoint ok', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Save Full App State",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"centerId\": \"{{centerId}}\",\n  \"state\": {\n    \"settings\": {\n      \"centerName\": \"فيجين التحصيل\",\n      \"centerId\": \"{{centerId}}\",\n      \"sidebarIcon\": \"🎯\"\n    },\n    \"students\": [],\n    \"attendance\": [],\n    \"payments\": [],\n    \"groups\": [],\n    \"teachers\": [],\n    \"exams\": [],\n    \"homework\": [],\n    \"whatsapp\": [],\n    \"rooms\": [],\n    \"expenses\": [],\n    \"staff\": [],\n    \"leads\": [],\n    \"complaints\": []\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/state",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "state"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('state saved', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().ok).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Student Record",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"centerId\": \"{{centerId}}\",\n  \"record\": {\n    \"code\": \"STU-TEST\",\n    \"name\": \"طالب تجربة\",\n    \"parentPhone\": \"01000000000\",\n    \"grade\": \"الثالث الثانوي\",\n    \"subject\": \"أحياء\",\n    \"status\": \"مستمر\",\n    \"subscription\": 500\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "students"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('student created', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.data && json.data.id) pm.environment.set('recordId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "List Student Records",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students?centerId={{centerId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "students"
          ],
          "query": [
            {
              "key": "centerId",
              "value": "{{centerId}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('students listed', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().data).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Student Record",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"centerId\": \"{{centerId}}\",\n  \"record\": {\n    \"code\": \"STU-TEST\",\n    \"name\": \"طالب تجربة معدل\",\n    \"parentPhone\": \"01000000000\",\n    \"grade\": \"الثالث الثانوي\",\n    \"subject\": \"أحياء\",\n    \"status\": \"مستمر\",\n    \"subscription\": 650\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/students/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "students",
            "{{recordId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('student updated', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().data.name).to.include('معدل'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Student Record",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students/{{recordId}}?centerId={{centerId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "students",
            "{{recordId}}"
          ],
          "query": [
            {
              "key": "centerId",
              "value": "{{centerId}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('student deleted', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().ok).to.eql(true); });"
            ]
          }
        }
      ]
    }
  ]
}